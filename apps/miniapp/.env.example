# Frontend API base URL for production (e.g. Render)
# Example:
# VITE_API_BASE_URL=https://your-backend.onrender.com

# Leave empty for local development with Vite proxy.
VITE_API_BASE_URL=

# Local development fallback user id used when Telegram context is unavailable.
# In Telegram Mini App runtime, real Telegram user id is always used first.
VITE_DEV_USER_ID=1234


